# ── API (required in production on Vercel) ─────────────────────────────────────
# Your Render backend URL, no trailing slash:
# VITE_API_URL=https://food-buddy-api.onrender.com

# Leave empty in local dev — Vite proxies /api to the backend.
VITE_API_URL=

# ── Local dev server ───────────────────────────────────────────────────────────
VITE_DEV_PORT=5173
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080

# ── Map routing (optional — defaults to public OSRM) ───────────────────────────
VITE_OSRM_URL=https://router.project-osrm.org/route/v1/driving
